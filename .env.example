# Copiez ce fichier en ".env" pour un test en local, puis remplissez les
# valeurs. Ne commitez JAMAIS le fichier ".env" réel (il est ignoré par
# .gitignore). En production (GitHub Actions), ces valeurs proviennent
# des GitHub Secrets, pas de ce fichier.

EMAIL_SENDER=votre.adresse@gmail.com
EMAIL_PASSWORD=xxxxxxxxxxxxxxxx
EMAIL_RECEIVER=destinataire@example.com

# Optionnel : décommentez pour tester sans envoyer d'e-mail réel
# DRY_RUN=1

# Optionnel : ajustements avancés (valeurs par défaut déjà raisonnables)
# TARGET_URL=https://trouverunlogement.lescrous.fr/tools/47/search?bounds=5.6776059_45.2140762_5.7531176_45.1541442&locationName=Grenoble
# CITY_NAME=Grenoble
# REQUEST_TIMEOUT=15
# MAX_RETRIES=4
# BACKOFF_BASE_SECONDS=2
# LOG_LEVEL=INFO
